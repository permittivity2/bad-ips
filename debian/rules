#!/usr/bin/make -f

# Debian package build rules for bad-ips
# Uses debhelper for standard Debian packaging

%:
	dh $@

# Don't use the Makefile for building - it's just a convenience wrapper
# The Makefile is for users, not for debian packaging
override_dh_auto_clean:
	# Nothing to clean - pure Perl package

override_dh_auto_build:
	# Nothing to build - pure Perl package

override_dh_auto_test:
	# No automated tests to run

override_dh_auto_install:
	# Don't use 'make install' - use dh_install with debian/install instead
	dh_install

# Skip dh_usrlocal - we intentionally install to /usr/local/
override_dh_usrlocal:
	# Bad IPs intentionally uses /usr/local/ for Perl modules

# Override to ensure permissions are correct after install
override_dh_fixperms:
	dh_fixperms
	# Ensure executables have correct permissions
	chmod +x debian/bad-ips/usr/local/sbin/bad_ips
	chmod +x debian/bad-ips/usr/local/sbin/bad_ips_installer.sh
	chmod +x debian/bad-ips/usr/local/share/bad_ips/migrate_database_v2.pl
